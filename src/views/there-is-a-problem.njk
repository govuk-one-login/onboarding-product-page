{% extends "base.njk" %}

{% set pageTitle = "There is a problem with the service" %}

{% block mainContent %}
  <h1 class="govuk-heading-l">Sorry, there is a problem with the service</h1>

  <p class="govuk-body">Try again later.</p>

  {% if showLinkToContactForm %}
    <p class="govuk-body">
      You can contact us using our <a class="govuk-link" href="https://onelogingovuk.service-now.com/csm?id=csm_sc_cat_item&sys_id=83902cb51b4822900a549978b04bcbed">support form</a> if it happens again.
    </p>
  {% endif %}
{% endblock %}
